# Binance Futures API
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret

# Paper Trading 模式 (true = 真实行情 + 模拟执行, false = 真实交易)
PAPER_TRADING=true
# PAPER_INITIAL_BALANCE=2000
# PAPER_DATA_DIR=data/paper

# PostgreSQL
DATABASE_URL=postgresql://localhost:5432/claude_trader

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# WebSocket 实时监控
# WS_EVAL_MAX_BUDGET=0.30    # 每次 AI 评估最大成本
# WS_EVAL_TIMEOUT=120         # AI 评估超时 (秒)
